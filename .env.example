# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# App
NEXT_PUBLIC_BASE_URL="https://genbacareer.jp"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# LINE Login (optional)
LINE_CLIENT_ID=""
LINE_CLIENT_SECRET=""

# Stripe (optional)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# SendGrid (optional - falls back to console.log in dev)
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@genbacareer.jp"

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=""

# Google Search Console verification (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# Admin credentials (optional - enable admin login)
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
ADMIN_EMAIL=""
ADMIN_PASSWORD_HASH=""

# Cron job authentication (optional)
CRON_SECRET=""

# Supabase Storage (for file uploads)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Meilisearch (optional)
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""
