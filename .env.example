# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# App
NEXT_PUBLIC_BASE_URL="https://genbacareer.jp"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# LINE Login (optional)
LINE_CLIENT_ID=""
LINE_CLIENT_SECRET=""

# Stripe (optional - カード決済を使う企業向け)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# マネーフォワード クラウド請求書 (optional - 銀行振込を使う企業向け)
# https://invoice.moneyforward.com/docs/api/v3/
MF_CLIENT_ID=""
MF_CLIENT_SECRET=""
MF_OFFICE_ID=""

# SendGrid (optional - falls back to console.log in dev)
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@genbacareer.jp"

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=""

# Google Search Console verification (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# Admin credentials (optional - enable admin login)
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
ADMIN_EMAIL=""
ADMIN_PASSWORD_HASH=""

# Cron job authentication (optional)
CRON_SECRET=""

# Supabase Storage (for file uploads)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Site URL (for OGP, email links, etc.)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# HelloWork connector API (server-only, NEVER expose to browser)
# - hellowork-api-connector プロジェクトの公開エンドポイント
# - 認証は X-API-Key ヘッダで行い、Route Handler 経由でブラウザに転送する
JOBS_API_BASE_URL=""
JOBS_API_KEY=""
JOBS_API_TIMEOUT_MS="8000"

# Meilisearch (optional)
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""

# HelloWork 求人情報提供 API (https://teikyo.hellowork.mhlw.go.jp/teikyo/api/2.0/)
HELLOWORK_API_USER=""
HELLOWORK_API_PASS=""
HELLOWORK_API_BASE="https://teikyo.hellowork.mhlw.go.jp/teikyo/api/2.0"

# Admin API key (for /api/admin/* batch endpoints)
ADMIN_API_KEY=""
