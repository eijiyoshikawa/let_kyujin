# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# LINE Login (optional)
LINE_CLIENT_ID=""
LINE_CLIENT_SECRET=""

# Stripe (optional)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# SendGrid (optional - falls back to console.log in dev)
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@example.com"

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=""

# Google Search Console verification (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# Admin credentials (optional - enable admin login)
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
ADMIN_EMAIL=""
ADMIN_PASSWORD_HASH=""

# Cron job authentication (optional)
CRON_SECRET=""

# Supabase Storage (for file uploads)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Site URL (for OGP, email links, etc.)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# HelloWork connector API (server-only, NEVER expose to browser)
# - hellowork-api-connector プロジェクトの公開エンドポイント
# - 認証は X-API-Key ヘッダで行い、Route Handler 経由でブラウザに転送する
JOBS_API_BASE_URL=""
JOBS_API_KEY=""
JOBS_API_TIMEOUT_MS="8000"
