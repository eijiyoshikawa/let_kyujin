generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// 求職者
// ========================================
model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique @db.VarChar(255)
  passwordHash      String?   @map("password_hash") @db.VarChar(255)
  name              String?   @db.VarChar(100)
  phone             String?   @db.VarChar(20)
  prefecture        String?   @db.VarChar(10)
  city              String?   @db.VarChar(50)
  birthDate         DateTime? @map("birth_date") @db.Date
  desiredCategories String[]  @default([]) @map("desired_categories")
  desiredSalaryMin  Int?      @map("desired_salary_min")
  resumeUrl         String?   @map("resume_url") @db.VarChar(500)
  profilePublic     Boolean   @default(false) @map("profile_public")
  authProvider      String    @default("email") @map("auth_provider") @db.VarChar(20)
  emailVerified     DateTime? @map("email_verified") @db.Timestamptz()
  verificationToken String?   @unique @map("verification_token") @db.VarChar(64)
  verificationTokenExpiry DateTime? @map("verification_token_expiry") @db.Timestamptz()
  resetToken        String?   @unique @map("reset_token") @db.VarChar(64)
  resetTokenExpiry  DateTime? @map("reset_token_expiry") @db.Timestamptz()
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  applications      Application[]
  scouts            Scout[]
  resume            Resume?
  uploadedFiles     UploadedFile[]
  applicationClicks ApplicationClick[]

  @@map("users")
}

// ========================================
// 掲載企業
// ========================================
model Company {
  id               String   @id @default(uuid()) @db.Uuid
  // 掲載元: direct(自社掲載企業) | hellowork(HelloWork API 由来の参照データ)
  source           String   @default("direct") @db.VarChar(20)
  name             String   @db.VarChar(200)
  industry         String?  @db.VarChar(100)
  prefecture       String?  @db.VarChar(10)
  city             String?  @db.VarChar(50)
  address          String?
  employeeCount    String?  @map("employee_count") @db.VarChar(50)
  description      String?
  logoUrl          String?  @map("logo_url") @db.VarChar(500)
  websiteUrl       String?  @map("website_url") @db.VarChar(500)
  contactEmail     String?  @map("contact_email") @db.VarChar(255)
  stripeCustomerId String?  @map("stripe_customer_id") @db.VarChar(100)
  // マネーフォワード クラウド請求書の取引先 ID
  mfPartnerId      String?  @map("mf_partner_id") @db.VarChar(100)
  // 支払方法: stripe(カード) | moneyforward(請求書+銀行振込)
  paymentMethod    String   @default("stripe") @map("payment_method") @db.VarChar(20)
  // 承認ステータス: pending(申請中) | approved(承認済) | rejected(却下)
  // HelloWork 由来の参照企業は承認フローの対象外なので "approved" 固定
  status           String   @default("pending") @db.VarChar(20)
  approvedAt       DateTime? @map("approved_at") @db.Timestamptz()
  rejectedAt       DateTime? @map("rejected_at") @db.Timestamptz()
  rejectionReason  String?   @map("rejection_reason")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // 求人詳細ページ用のリッチコンテンツ。すべて nullable。
  // tagline はメガホン枠の 1 行キャッチコピー
  tagline           String? @db.VarChar(200)
  // 「こんなトコロがすごい！」自社の魅力ポイント
  pitchHighlights   String? @map("pitch_highlights")
  // 「こんな人が向いています！」求める人物像
  idealCandidate    String? @map("ideal_candidate")
  // 「働いている社員の声」employee voice
  employeeVoice     String? @map("employee_voice")
  // 求人写真ギャラリー（最大 12 枚想定、URL のみ保持。ストレージ上限は別途運用で管理）
  photos            String[] @default([])

  // SNS リンク（5 種）
  instagramUrl      String? @map("instagram_url") @db.VarChar(500)
  tiktokUrl         String? @map("tiktok_url") @db.VarChar(500)
  facebookUrl       String? @map("facebook_url") @db.VarChar(500)
  xUrl              String? @map("x_url") @db.VarChar(500)
  youtubeUrl        String? @map("youtube_url") @db.VarChar(500)

  // 求人一覧のソート順決定に使う。リッチコンテンツが最後に更新された日時。
  // 3 ヶ月以内に更新されているかが「活性企業」の指標になる。
  lastContentUpdatedAt DateTime? @map("last_content_updated_at") @db.Timestamptz()

  companyUsers  CompanyUser[]
  jobs          Job[]
  scouts        Scout[]
  billingEvents BillingEvent[]
  applications  Application[]

  @@unique([source, name], name: "company_source_name_unique")
  @@index([status], name: "idx_companies_status")
  @@index([source], name: "idx_companies_source")
  @@index([lastContentUpdatedAt(sort: Desc)], name: "idx_companies_last_content")
  @@map("companies")
}

// ========================================
// 企業担当者アカウント
// ========================================
model CompanyUser {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  name         String?  @db.VarChar(100)
  role         String   @default("member") @db.VarChar(20) // admin | member
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_users")
}

// ========================================
// 求人情報
// ========================================
model Job {
  id             String    @id @default(uuid()) @db.Uuid
  companyId      String?   @map("company_id") @db.Uuid
  source         String    @default("direct") @db.VarChar(20) // direct | hellowork
  helloworkId    String?   @unique @map("hellowork_id") @db.VarChar(50)
  title          String    @db.VarChar(500)
  category       String    @db.VarChar(50) // driver | construction | manufacturing | other
  subcategory    String?   @db.VarChar(50)
  employmentType String?   @map("employment_type") @db.VarChar(20) // full_time | part_time | contract
  description    String?
  requirements   String?
  salaryMin      Int?      @map("salary_min")
  salaryMax      Int?      @map("salary_max")
  salaryType     String?   @map("salary_type") @db.VarChar(20) // monthly | hourly | annual
  prefecture     String    @db.VarChar(20)
  city           String?   @db.VarChar(100)
  address        String?
  benefits       String[]  @default([])
  tags           String[]  @default([])
  status         String    @default("active") @db.VarChar(20) // draft | active | closed
  publishedAt    DateTime? @map("published_at") @db.Timestamptz()
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz()
  viewCount      Int       @default(0) @map("view_count")
  // 求人一覧の「おすすめ順」で使うスコア。
  // 内容量・SNS 登録数・写真数・3 ヶ月以内更新を加点で評価する（ranking.ts 参照）。
  // 取り込み時 / 企業プロフィール保存時に再計算される。
  rankScore      Int       @default(0) @map("rank_score")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  company           Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  applications      Application[]
  scouts            Scout[]
  applicationClicks ApplicationClick[]

  @@index([prefecture, category, employmentType, status], name: "idx_jobs_search")
  @@index([salaryMin, salaryMax], name: "idx_jobs_salary")
  @@index([status, publishedAt(sort: Desc)], name: "idx_jobs_status_published")
  @@index([status, rankScore(sort: Desc), publishedAt(sort: Desc)], name: "idx_jobs_status_rank")
  @@map("jobs")
}

// ========================================
// 応募
// ========================================
model Application {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  companyId String?  @map("company_id") @db.Uuid
  status    String   @default("applied") @db.VarChar(20) // applied | reviewing | interview | offered | hired | rejected
  message   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  job          Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  billingEvent BillingEvent?

  @@unique([jobId, userId])
  @@map("applications")
}

// ========================================
// 応募ボタンクリック計測（LINE 集約導線）
// ========================================
// 「LINE で応募」ボタンが押された瞬間に記録する。
// 実際の応募成立は LINE 上で運営が確認するため、本テーブルは「興味を持った数」
// （リード）の指標として使う。userId は未ログイン時 null。
model ApplicationClick {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  source    String   @default("job_detail") @db.VarChar(20) // job_card | job_detail | apply_page
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  referer   String?  @db.VarChar(500)
  clickedAt DateTime @default(now()) @map("clicked_at") @db.Timestamptz()

  job  Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([jobId, clickedAt(sort: Desc)], name: "idx_app_clicks_job_time")
  @@index([userId, clickedAt(sort: Desc)], name: "idx_app_clicks_user_time")
  @@map("application_clicks")
}

// ========================================
// スカウト
// ========================================
model Scout {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  jobId     String?   @map("job_id") @db.Uuid
  message   String?
  status    String    @default("sent") @db.VarChar(20) // sent | read | replied | declined
  sentAt    DateTime  @default(now()) @map("sent_at") @db.Timestamptz()
  readAt    DateTime? @map("read_at") @db.Timestamptz()

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  job     Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@map("scouts")
}

// ========================================
// 成果報酬課金
// ========================================
model BillingEvent {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  applicationId   String   @unique @map("application_id") @db.Uuid
  eventType       String   @map("event_type") @db.VarChar(20) // hired
  amount          Int // 成果報酬金額（円）
  // 請求書発行プロバイダ: stripe | moneyforward
  provider        String   @default("stripe") @db.VarChar(20)
  stripeInvoiceId String?  @map("stripe_invoice_id") @db.VarChar(100)
  // マネーフォワード クラウド請求書の請求書 ID
  mfBillingId     String?  @map("mf_billing_id") @db.VarChar(100)
  // 請求書 PDF / Web 公開 URL
  invoiceUrl      String?  @map("invoice_url") @db.VarChar(500)
  status          String   @default("pending") @db.VarChar(20) // pending | invoiced | paid | failed
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("billing_events")
}

// ========================================
// 履歴書・職務経歴書（アプリ内作成）
// ========================================
model Resume {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  // 基本情報
  fullName      String?  @map("full_name") @db.VarChar(100)
  furigana      String?  @db.VarChar(100)
  birthDate     DateTime? @map("birth_date") @db.Date
  gender        String?  @db.VarChar(10)
  postalCode    String?  @map("postal_code") @db.VarChar(10)
  address       String?
  phone         String?  @db.VarChar(20)
  email         String?  @db.VarChar(255)
  photo         String?  @db.VarChar(500) // 証明写真URL

  // 学歴・職歴 (JSON配列)
  educationHistory Json? @map("education_history") @db.JsonB // [{year, month, content}]
  workHistory      Json? @map("work_history") @db.JsonB      // [{year, month, content}]

  // 免許・資格 (JSON配列)
  licenses Json? @db.JsonB // [{year, month, name}]

  // 志望動機・自己PR
  motivation String?
  selfPr     String? @map("self_pr")

  // 職務経歴書
  careerSummary    String?  @map("career_summary")  // 職務要約
  careerDetails    Json?    @map("career_details") @db.JsonB // [{company, period, position, description}]
  skills           String[] @default([])              // 保有スキル
  qualifications   String[] @default([])              // 資格一覧

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resumes")
}

// ========================================
// アップロードファイル
// ========================================
model UploadedFile {
  id       String @id @default(uuid()) @db.Uuid
  userId   String @map("user_id") @db.Uuid
  fileName String @map("file_name") @db.VarChar(255)
  fileType String @map("file_type") @db.VarChar(20) // resume | cv | other
  fileUrl  String @map("file_url") @db.VarChar(500)
  fileSize Int    @map("file_size") // bytes
  mimeType String @map("mime_type") @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("uploaded_files")
}

// ========================================
// マガジン記事
// ========================================
model Article {
  id              String    @id @default(uuid()) @db.Uuid
  slug            String    @unique @db.VarChar(200)
  title           String    @db.VarChar(200)
  excerpt         String?   @db.VarChar(500)
  body            String    // HTML本文
  category        String    @db.VarChar(50) // career, salary, license, job-type, industry, interview
  subcategory     String?   @db.VarChar(50) // construction: civil | building | equipment | electrical | plumbing | demolition | interior | exterior | reinforcing | heavy_equipment | surveying | safety | tips
  tags            String[]  @default([])
  imageUrl        String?   @map("image_url") @db.VarChar(500)
  metaDescription String?   @map("meta_description") @db.VarChar(300)
  authorName      String    @default("建設求人ポータル編集部") @map("author_name") @db.VarChar(100)
  status          String    @default("published") @db.VarChar(20) // draft | published
  featured        Boolean   @default(false)
  viewCount       Int       @default(0) @map("view_count")
  publishedAt     DateTime? @map("published_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([status, publishedAt(sort: Desc)], name: "idx_articles_published")
  @@index([category, status], name: "idx_articles_category")
  @@map("articles")
}

// ========================================
// 外部 API 取り込み進捗
// HelloWork 全国 36 万件の (dataId, page) ローテーション状態を保持する
// ========================================
model ImportProgress {
  id           String    @id @default(uuid()) @db.Uuid
  source       String    @db.VarChar(20)  // "hellowork"
  dataId       String    @map("data_id") @db.VarChar(20)  // e.g. "M100"
  lastPage     Int       @default(0) @map("last_page")  // 直近で完了したページ番号 (0=未着手)
  exhausted    Boolean   @default(false)  // 末尾ページに到達したら true
  totalFetched Int       @default(0) @map("total_fetched")
  lastRunAt    DateTime? @map("last_run_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([source, dataId])
  @@map("import_progress")
}

// ========================================
// SEOランディングページ
// ========================================
model SeoPage {
  id              String   @id @default(uuid()) @db.Uuid
  slug            String   @unique @db.VarChar(200) // e.g. "tokyo-driver"
  prefecture      String   @db.VarChar(10)
  category        String   @db.VarChar(50)
  title           String   @db.VarChar(200)
  metaDescription String?  @map("meta_description") @db.VarChar(300)
  h1Text          String?  @map("h1_text") @db.VarChar(200)
  bodyContent     String?  @map("body_content")
  jobCount        Int      @default(0) @map("job_count")
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("seo_pages")
}
