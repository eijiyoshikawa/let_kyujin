generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// 求職者
// ========================================
model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique @db.VarChar(255)
  passwordHash      String?   @map("password_hash") @db.VarChar(255)
  name              String?   @db.VarChar(100)
  phone             String?   @db.VarChar(20)
  prefecture        String?   @db.VarChar(10)
  city              String?   @db.VarChar(50)
  birthDate         DateTime? @map("birth_date") @db.Date
  desiredCategories String[]  @default([]) @map("desired_categories")
  desiredSalaryMin  Int?      @map("desired_salary_min")
  resumeUrl         String?   @map("resume_url") @db.VarChar(500)
  profilePublic     Boolean   @default(false) @map("profile_public")
  authProvider      String    @default("email") @map("auth_provider") @db.VarChar(20)
  emailVerified     DateTime? @map("email_verified") @db.Timestamptz()
  verificationToken String?   @unique @map("verification_token") @db.VarChar(64)
  verificationTokenExpiry DateTime? @map("verification_token_expiry") @db.Timestamptz()
  resetToken        String?   @unique @map("reset_token") @db.VarChar(64)
  resetTokenExpiry  DateTime? @map("reset_token_expiry") @db.Timestamptz()
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  applications      Application[]
  scouts            Scout[]
  resume            Resume?
  uploadedFiles     UploadedFile[]
  applicationClicks ApplicationClick[]
  jobViews          JobView[]
  notifications     Notification[]
  savedSearches     SavedSearch[]
  messageTemplates  ApplicationMessageTemplate[]

  @@map("users")
}

// ========================================
// 応募メッセージ テンプレート
// ========================================
// 求職者が応募フォームの「ご質問・希望条件」欄にすばやく挿入できる定型文。
// 1 ユーザーあたり 10 件まで（API で制限）。
model ApplicationMessageTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(60)
  body      String
  sortOrder Int      @default(100) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder], name: "idx_app_msg_tpl_user")
  @@map("application_message_templates")
}

// ========================================
// 検索保存・新着アラート
// ========================================
// 求職者が条件を保存し、日次バッチで新着求人をマッチさせて inbox / LINE に通知する。
model SavedSearch {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  // ユーザーが見つけやすいよう自分で付ける名前。空なら自動生成。
  name           String   @db.VarChar(100)
  // フィルタ条件（/jobs のクエリと同じ意味論）
  q              String?  @db.VarChar(200)
  prefecture     String?  @db.VarChar(20)
  city           String?  @db.VarChar(100)
  category       String?  @db.VarChar(50)
  employmentType String?  @map("employment_type") @db.VarChar(20)
  salaryMin      Int?     @map("salary_min")
  source         String?  @db.VarChar(20) // direct | hellowork、null なら両方
  // 通知設定
  alertEnabled   Boolean  @default(true) @map("alert_enabled")
  // 最後にスキャンした時刻。これより新しい publishedAt を新着とみなす。
  lastNotifiedAt DateTime? @map("last_notified_at") @db.Timestamptz()
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], name: "idx_saved_searches_user")
  @@index([alertEnabled, lastNotifiedAt], name: "idx_saved_searches_alert")
  @@map("saved_searches")
}

// ========================================
// 管理者・企業ユーザーの監査ログ
// ========================================
// 重要な操作（求人の承認/却下、テンプレ編集、企業情報更新、応募ステータス変更 等）
// を時系列で保存する。
//   - actorType: admin | company_user | system
//   - resourceType: company | job | job_template | application | line_lead | scout | ...
//   - action: create | update | delete | approve | reject | login | …（自由形式 VarChar）
//   - diff: 任意のスナップショット / 差分 JSON
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorType    String   @map("actor_type") @db.VarChar(20)
  actorId      String?  @map("actor_id") @db.VarChar(64)
  actorEmail   String?  @map("actor_email") @db.VarChar(255)
  resourceType String   @map("resource_type") @db.VarChar(40)
  resourceId   String?  @map("resource_id") @db.VarChar(64)
  action       String   @db.VarChar(40)
  // 1 行サマリ（一覧に出すラベル）
  summary      String?  @db.VarChar(500)
  // 任意の追加情報・差分（前後の値、IP、UA など）
  diff         Json?
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([resourceType, resourceId, createdAt(sort: Desc)], name: "idx_audit_resource")
  @@index([actorType, actorId, createdAt(sort: Desc)], name: "idx_audit_actor")
  @@index([createdAt(sort: Desc)], name: "idx_audit_created")
  @@map("audit_logs")
}

// ========================================
// 求人投稿テンプレート（管理者運用）
// ========================================
// 求人投稿ウィザードで利用できるカテゴリ別ひな型。
// 静的データとして src/lib/job-templates.ts に持っていたものを DB 化し、
// 管理者画面から自由に編集できるようにしたもの。
model JobTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  // 一意な slug（旧静的データ互換のため、初回 seed では "construction-tobi" 等）
  slug        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(100)
  category    String   @db.VarChar(50)
  description String
  requirements String?
  benefits    String[] @default([])
  tags        String[] @default([])
  salaryMin   Int?     @map("salary_min")
  salaryMax   Int?     @map("salary_max")
  hint        String?  @db.VarChar(500)
  // 並び順（数値小さい順、同点はカテゴリ → 名前）
  sortOrder   Int      @default(100) @map("sort_order")
  // 利用可否（false にすると wizard には出ない）
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([isActive, sortOrder], name: "idx_job_templates_listing")
  @@map("job_templates")
}

// ========================================
// 求職者向け通知
// ========================================
// マイページの通知センターに表示する inbox 行。
// メール / LINE への配信は別経路で行い、本テーブルは「未読・既読」を管理する。
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  // application_status | scout_received | system | promo
  type      String   @db.VarChar(30)
  title     String   @db.VarChar(200)
  body      String?
  // クリック時の遷移先（/mypage/applications/<id> 等）
  linkUrl   String?  @map("link_url") @db.VarChar(500)
  // 既読日時。null なら未読。
  readAt    DateTime? @map("read_at") @db.Timestamptz()
  // 関連リソースの id（applicationId / scoutId / jobId 等）
  refId     String?  @map("ref_id") @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt(sort: Desc)], name: "idx_notifications_user_inbox")
  @@map("notifications")
}

// ========================================
// 掲載企業
// ========================================
model Company {
  id               String   @id @default(uuid()) @db.Uuid
  // 掲載元: direct(自社掲載企業) | hellowork(HelloWork API 由来の参照データ)
  source           String   @default("direct") @db.VarChar(20)
  name             String   @db.VarChar(200)
  industry         String?  @db.VarChar(100)
  prefecture       String?  @db.VarChar(10)
  city             String?  @db.VarChar(50)
  address          String?
  employeeCount    String?  @map("employee_count") @db.VarChar(50)
  description      String?
  logoUrl          String?  @map("logo_url") @db.VarChar(500)
  websiteUrl       String?  @map("website_url") @db.VarChar(500)
  contactEmail     String?  @map("contact_email") @db.VarChar(255)
  stripeCustomerId String?  @map("stripe_customer_id") @db.VarChar(100)
  // マネーフォワード クラウド請求書の取引先 ID
  mfPartnerId      String?  @map("mf_partner_id") @db.VarChar(100)
  // 支払方法: stripe(カード) | moneyforward(請求書+銀行振込)
  paymentMethod    String   @default("stripe") @map("payment_method") @db.VarChar(20)
  // 承認ステータス: pending(申請中) | approved(承認済) | rejected(却下)
  // HelloWork 由来の参照企業は承認フローの対象外なので "approved" 固定
  status           String   @default("pending") @db.VarChar(20)
  approvedAt       DateTime? @map("approved_at") @db.Timestamptz()
  rejectedAt       DateTime? @map("rejected_at") @db.Timestamptz()
  rejectionReason  String?   @map("rejection_reason")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // 求人詳細ページ用のリッチコンテンツ。すべて nullable。
  // tagline はメガホン枠の 1 行キャッチコピー
  tagline           String? @db.VarChar(200)
  // 「こんなトコロがすごい！」自社の魅力ポイント
  pitchHighlights   String? @map("pitch_highlights")
  // 「こんな人が向いています！」求める人物像
  idealCandidate    String? @map("ideal_candidate")
  // 「働いている社員の声」employee voice
  employeeVoice     String? @map("employee_voice")
  // 求人写真ギャラリー（最大 12 枚想定、URL のみ保持。ストレージ上限は別途運用で管理）
  photos            String[] @default([])

  // SNS リンク（5 種）
  instagramUrl      String? @map("instagram_url") @db.VarChar(500)
  tiktokUrl         String? @map("tiktok_url") @db.VarChar(500)
  facebookUrl       String? @map("facebook_url") @db.VarChar(500)
  xUrl              String? @map("x_url") @db.VarChar(500)
  youtubeUrl        String? @map("youtube_url") @db.VarChar(500)

  // 求人一覧のソート順決定に使う。リッチコンテンツが最後に更新された日時。
  // 3 ヶ月以内に更新されているかが「活性企業」の指標になる。
  lastContentUpdatedAt DateTime? @map("last_content_updated_at") @db.Timestamptz()

  companyUsers  CompanyUser[]
  jobs          Job[]
  scouts        Scout[]
  billingEvents BillingEvent[]
  applications  Application[]

  @@unique([source, name], name: "company_source_name_unique")
  @@index([status], name: "idx_companies_status")
  @@index([source], name: "idx_companies_source")
  @@index([lastContentUpdatedAt(sort: Desc)], name: "idx_companies_last_content")
  @@map("companies")
}

// ========================================
// 企業担当者アカウント
// ========================================
model CompanyUser {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  name         String?  @db.VarChar(100)
  role         String   @default("member") @db.VarChar(20) // admin | member
  // TOTP 2FA (RFC 6238). 有効化後はログイン時に 6 桁コードが必須。
  // totpSecret は base32 エンコード（otplib のデフォルト）。
  totpSecret      String?  @map("totp_secret") @db.VarChar(64)
  totpEnabled     Boolean  @default(false) @map("totp_enabled")
  totpEnabledAt   DateTime? @map("totp_enabled_at") @db.Timestamptz()
  // 1 回限りのリカバリコード（ハッシュ化 [bcrypt] して保存。1 件 60 char 程度）
  totpRecoveryCodes String[] @default([]) @map("totp_recovery_codes")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_users")
}

// ========================================
// 求人情報
// ========================================
model Job {
  id             String    @id @default(uuid()) @db.Uuid
  companyId      String?   @map("company_id") @db.Uuid
  source         String    @default("direct") @db.VarChar(20) // direct | hellowork
  helloworkId    String?   @unique @map("hellowork_id") @db.VarChar(50)
  title          String    @db.VarChar(500)
  category       String    @db.VarChar(50) // driver | construction | manufacturing | other
  subcategory    String?   @db.VarChar(50)
  employmentType String?   @map("employment_type") @db.VarChar(20) // full_time | part_time | contract
  description    String?
  requirements   String?
  salaryMin      Int?      @map("salary_min")
  salaryMax      Int?      @map("salary_max")
  salaryType     String?   @map("salary_type") @db.VarChar(20) // monthly | hourly | annual
  prefecture     String    @db.VarChar(20)
  city           String?   @db.VarChar(100)
  address        String?
  benefits       String[]  @default([])
  tags           String[]  @default([])
  // 動画求人用の埋め込み URL（YouTube / TikTok / Vimeo を想定、最大 6 本）
  videoUrls      String[]  @default([]) @map("video_urls")
  status         String    @default("active") @db.VarChar(20) // draft | active | closed
  publishedAt    DateTime? @map("published_at") @db.Timestamptz()
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz()
  viewCount      Int       @default(0) @map("view_count")
  // 下書き状態でも社内チェック用に共有できるプレビュートークン（hex）。
  // 未設定なら「プレビュー URL を発行」ボタンで生成する。
  previewToken   String?   @unique @map("preview_token") @db.VarChar(64)
  // 求人一覧の「おすすめ順」で使うスコア。
  // 内容量・SNS 登録数・写真数・3 ヶ月以内更新を加点で評価する（ranking.ts 参照）。
  // 取り込み時 / 企業プロフィール保存時に再計算される。
  rankScore      Int       @default(0) @map("rank_score")

  // ハローワーク API 由来の拡張フィールド（C案ハイブリッド: 主要項目を個別カラム化）
  occupationTitle        String?   @map("occupation_title") @db.VarChar(100)
  jobConditionNotes      String?   @map("job_condition_notes")
  industryCode           String?   @map("industry_code") @db.VarChar(10)
  industryMajorCode      String?   @map("industry_major_code") @db.VarChar(5)
  occupationCode         String?   @map("occupation_code") @db.VarChar(10)
  occupationCategoryName String?   @map("occupation_category_name") @db.VarChar(50)
  jobTypeName            String?   @map("job_type_name") @db.VarChar(20)
  baseSalary             String?   @map("base_salary") @db.VarChar(50)
  bonus                  String?   @db.VarChar(100)
  commuteAllowance       String?   @map("commute_allowance") @db.VarChar(50)
  fixedOvertime          String?   @map("fixed_overtime") @db.VarChar(100)
  workHours              String?   @map("work_hours") @db.VarChar(100)
  workHoursNotes         String?   @map("work_hours_notes") @db.VarChar(255)
  holidays               String?   @db.VarChar(50)
  holidaysOther          String?   @map("holidays_other") @db.VarChar(200)
  annualHolidays         Int?      @map("annual_holidays")
  insurance              String?   @db.VarChar(50)
  smokingPolicy          String?   @map("smoking_policy") @db.VarChar(20)
  trialPeriod            String?   @map("trial_period") @db.VarChar(100)
  requiredExperience     String?   @map("required_experience") @db.VarChar(500)
  education              String?   @db.VarChar(50)
  recruitmentCount       String?   @map("recruitment_count") @db.VarChar(10)
  recruitmentReason      String?   @map("recruitment_reason") @db.VarChar(20)
  companyFeatures        String?   @map("company_features")
  businessContent        String?   @map("business_content")
  companyUrl             String?   @map("company_url") @db.VarChar(255)
  validUntil             DateTime? @map("valid_until") @db.Date
  receivedDate           DateTime? @map("received_date") @db.Date
  // 上記以外の API タグを丸ごと格納
  rawData                Json?     @map("raw_data")

  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  company           Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  applications      Application[]
  scouts            Scout[]
  applicationClicks ApplicationClick[]
  lineLeads         LineLead[]
  jobViews          JobView[]

  @@index([prefecture, category, employmentType, status], name: "idx_jobs_search")
  @@index([salaryMin, salaryMax], name: "idx_jobs_salary")
  @@index([status, publishedAt(sort: Desc)], name: "idx_jobs_status_published")
  @@index([status, rankScore(sort: Desc), publishedAt(sort: Desc)], name: "idx_jobs_status_rank")
  @@index([industryMajorCode], name: "idx_jobs_industry_major")
  @@map("jobs")
}

// ========================================
// 応募
// ========================================
model Application {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  companyId String?  @map("company_id") @db.Uuid
  status    String   @default("applied") @db.VarChar(20) // applied | reviewing | interview | offered | hired | rejected
  message   String?
  // 企業担当者用の社内メモ。求職者には公開しない。
  internalNotes String? @map("internal_notes")
  // 面接候補日時。複数候補をサポートするため Timestamptz[] で保持する（NULL = 未調整）。
  interviewSlots DateTime[] @default([]) @map("interview_slots") @db.Timestamptz()
  // 最終的に確定した面接日時。1 つだけ。
  interviewAt   DateTime? @map("interview_at") @db.Timestamptz()
  // 面接場所 / 案内（オンライン URL でも OK）
  interviewVenue String? @map("interview_venue") @db.VarChar(500)
  // ステータス遷移履歴（{ from, to, at, by, note }[]）
  statusHistory Json @default("[]") @map("status_history")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  job          Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  billingEvent BillingEvent?

  @@unique([jobId, userId])
  @@map("applications")
}

// ========================================
// 応募ボタンクリック計測（LINE 集約導線）
// ========================================
// 「LINE で応募」ボタンが押された瞬間に記録する。
// 実際の応募成立は LINE 上で運営が確認するため、本テーブルは「興味を持った数」
// （リード）の指標として使う。userId は未ログイン時 null。
model ApplicationClick {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  // 匿名ユーザーの追跡用 cookie (gc_sid) と GA4 client_id を紐付ける
  sessionId String?  @map("session_id") @db.VarChar(50)
  source    String   @default("job_detail") @db.VarChar(20) // job_card | job_detail | apply_page
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  referer   String?  @db.VarChar(500)
  clickedAt DateTime @default(now()) @map("clicked_at") @db.Timestamptz()

  job  Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([jobId, clickedAt(sort: Desc)], name: "idx_app_clicks_job_time")
  @@index([userId, clickedAt(sort: Desc)], name: "idx_app_clicks_user_time")
  @@map("application_clicks")
}

// ========================================
// LINE 応募ミニフォームから生成されるリード
// ========================================
// 求人詳細から「LINE で応募」を押すと、まずミニフォーム（氏名 / 電話 / メール 必須）
// を経由して当 LeadCapture に保存し、その後 LINE 公式アカウントへ遷移する。
// LINE 友だち追加後の Webhook で lineUserId が後追いで紐付く。
model LineLead {
  id              String   @id @default(uuid()) @db.Uuid
  jobId           String?  @map("job_id") @db.Uuid
  name            String   @db.VarChar(100)
  phone           String   @db.VarChar(30)
  email           String   @db.VarChar(255)
  prefecture      String?  @db.VarChar(10)
  experienceYears Int?     @map("experience_years")
  notes           String?
  // 匿名ユーザーの追跡用 cookie (gc_sid)。閲覧履歴との照合に使う
  sessionId       String?  @map("session_id") @db.VarChar(50)
  // 流入分析: UTM パラメータをサーバ側でも保存
  utmSource       String?  @map("utm_source") @db.VarChar(100)
  utmMedium       String?  @map("utm_medium") @db.VarChar(100)
  utmCampaign     String?  @map("utm_campaign") @db.VarChar(100)
  referer         String?  @db.VarChar(500)
  // 配信オプトアウト（true なら一括配信から除外）
  optedOut        Boolean  @default(false) @map("opted_out")
  optedOutAt      DateTime? @map("opted_out_at") @db.Timestamptz()
  // 'admin' | 'webhook' | 'manual'
  optedOutSource  String?  @map("opted_out_source") @db.VarChar(20)
  // LINE 友だち追加後の Webhook でセットされる
  lineUserId      String?  @map("line_user_id") @db.VarChar(50)
  lineDisplayName String?  @map("line_display_name") @db.VarChar(100)
  // pending | line_added | contacted | qualified | converted | rejected
  status          String   @default("pending") @db.VarChar(20)
  ipAddress       String?  @map("ip_address") @db.VarChar(45)
  userAgent       String?  @map("user_agent") @db.VarChar(500)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  job Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([jobId, createdAt(sort: Desc)], name: "idx_line_leads_job")
  @@index([lineUserId], name: "idx_line_leads_line_user")
  @@index([status, createdAt(sort: Desc)], name: "idx_line_leads_status")
  @@index([sessionId], name: "idx_line_leads_session")
  @@map("line_leads")
}

// ========================================
// 求人詳細ページの閲覧ログ
// ========================================
// 求人詳細ページ /jobs/[id] が表示されるたびに 1 行 INSERT。
// 匿名ユーザーを sessionId (gc_sid cookie) で同一識別し、
// lead 化前にどの求人を見ていたかをトラックする。
// admin 画面で「この lead がこれまで見た求人」一覧を表示する用途。
// 求人ごとの人気度集計にも使える。
model JobView {
  id          String   @id @default(uuid()) @db.Uuid
  jobId       String   @map("job_id") @db.Uuid
  sessionId   String?  @map("session_id") @db.VarChar(50)
  userId      String?  @map("user_id") @db.Uuid
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.VarChar(500)
  referer     String?  @db.VarChar(500)
  utmSource   String?  @map("utm_source") @db.VarChar(100)
  utmMedium   String?  @map("utm_medium") @db.VarChar(100)
  utmCampaign String?  @map("utm_campaign") @db.VarChar(100)
  viewedAt    DateTime @default(now()) @map("viewed_at") @db.Timestamptz()

  job  Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([jobId, viewedAt(sort: Desc)], name: "idx_job_views_job_time")
  @@index([sessionId, viewedAt(sort: Desc)], name: "idx_job_views_session_time")
  @@map("job_views")
}

// ========================================
// 一括 LINE Push 配信ログ
// ========================================
// admin から「セグメント配信」を実行したときの記録。
// 配信パラメータ + 結果（成功 / 失敗 / スキップ数）を残す。
model BroadcastLog {
  id            String   @id @default(uuid()) @db.Uuid
  // 配信時のセグメント条件（JSON: utm_source, category, prefecture, status, since, until 等）
  segment       Json
  // 配信対象求人 ID（最大 5 件）
  jobIds        String[] @map("job_ids") @db.Uuid
  freeText      String?  @map("free_text")
  // 集計
  targetCount   Int      @map("target_count")
  successCount  Int      @map("success_count")
  failureCount  Int      @map("failure_count")
  skippedCount  Int      @map("skipped_count") // line bind 未済等
  triggeredBy   String?  @map("triggered_by") @db.Uuid // 操作した admin user id
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([createdAt(sort: Desc)], name: "idx_broadcast_logs_time")
  @@map("broadcast_logs")
}

// ========================================
// スカウト
// ========================================
model Scout {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  jobId     String?   @map("job_id") @db.Uuid
  message   String?
  status    String    @default("sent") @db.VarChar(20) // sent | read | replied | declined
  sentAt    DateTime  @default(now()) @map("sent_at") @db.Timestamptz()
  readAt    DateTime? @map("read_at") @db.Timestamptz()

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  job     Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@map("scouts")
}

// ========================================
// 成果報酬課金
// ========================================
model BillingEvent {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  applicationId   String   @unique @map("application_id") @db.Uuid
  eventType       String   @map("event_type") @db.VarChar(20) // hired
  amount          Int // 成果報酬金額（円）
  // 請求書発行プロバイダ: stripe | moneyforward
  provider        String   @default("stripe") @db.VarChar(20)
  stripeInvoiceId String?  @map("stripe_invoice_id") @db.VarChar(100)
  // マネーフォワード クラウド請求書の請求書 ID
  mfBillingId     String?  @map("mf_billing_id") @db.VarChar(100)
  // 請求書 PDF / Web 公開 URL
  invoiceUrl      String?  @map("invoice_url") @db.VarChar(500)
  status          String   @default("pending") @db.VarChar(20) // pending | invoiced | paid | failed
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("billing_events")
}

// ========================================
// 履歴書・職務経歴書（アプリ内作成）
// ========================================
model Resume {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  // 基本情報
  fullName      String?  @map("full_name") @db.VarChar(100)
  furigana      String?  @db.VarChar(100)
  birthDate     DateTime? @map("birth_date") @db.Date
  gender        String?  @db.VarChar(10)
  postalCode    String?  @map("postal_code") @db.VarChar(10)
  address       String?
  phone         String?  @db.VarChar(20)
  email         String?  @db.VarChar(255)
  photo         String?  @db.VarChar(500) // 証明写真URL

  // 学歴・職歴 (JSON配列)
  educationHistory Json? @map("education_history") @db.JsonB // [{year, month, content}]
  workHistory      Json? @map("work_history") @db.JsonB      // [{year, month, content}]

  // 免許・資格 (JSON配列)
  licenses Json? @db.JsonB // [{year, month, name}]

  // 志望動機・自己PR
  motivation String?
  selfPr     String? @map("self_pr")

  // 職務経歴書
  careerSummary    String?  @map("career_summary")  // 職務要約
  careerDetails    Json?    @map("career_details") @db.JsonB // [{company, period, position, description}]
  skills           String[] @default([])              // 保有スキル
  qualifications   String[] @default([])              // 資格一覧

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resumes")
}

// ========================================
// アップロードファイル
// ========================================
model UploadedFile {
  id       String @id @default(uuid()) @db.Uuid
  userId   String @map("user_id") @db.Uuid
  fileName String @map("file_name") @db.VarChar(255)
  fileType String @map("file_type") @db.VarChar(20) // resume | cv | other
  fileUrl  String @map("file_url") @db.VarChar(500)
  fileSize Int    @map("file_size") // bytes
  mimeType String @map("mime_type") @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("uploaded_files")
}

// ========================================
// マガジン記事
// ========================================
model Article {
  id              String    @id @default(uuid()) @db.Uuid
  slug            String    @unique @db.VarChar(200)
  title           String    @db.VarChar(200)
  excerpt         String?   @db.VarChar(500)
  body            String    // HTML本文
  category        String    @db.VarChar(50) // career, salary, license, job-type, industry, interview
  subcategory     String?   @db.VarChar(50) // construction: civil | building | equipment | electrical | plumbing | demolition | interior | exterior | reinforcing | heavy_equipment | surveying | safety | tips
  tags            String[]  @default([])
  imageUrl        String?   @map("image_url") @db.VarChar(500)
  metaDescription String?   @map("meta_description") @db.VarChar(300)
  authorName      String    @default("建設求人ポータル編集部") @map("author_name") @db.VarChar(100)
  status          String    @default("published") @db.VarChar(20) // draft | published
  featured        Boolean   @default(false)
  viewCount       Int       @default(0) @map("view_count")
  publishedAt     DateTime? @map("published_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([status, publishedAt(sort: Desc)], name: "idx_articles_published")
  @@index([category, status], name: "idx_articles_category")
  @@map("articles")
}

// ========================================
// 外部 API 取り込み進捗
// HelloWork 全国 36 万件の (dataId, page) ローテーション状態を保持する
// ========================================
model ImportProgress {
  id           String    @id @default(uuid()) @db.Uuid
  source       String    @db.VarChar(20)  // "hellowork"
  dataId       String    @map("data_id") @db.VarChar(20)  // e.g. "M100"
  lastPage     Int       @default(0) @map("last_page")  // 直近で完了したページ番号 (0=未着手)
  exhausted    Boolean   @default(false)  // 末尾ページに到達したら true
  totalFetched Int       @default(0) @map("total_fetched")
  lastRunAt    DateTime? @map("last_run_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([source, dataId])
  @@map("import_progress")
}

// ========================================
// SEOランディングページ
// ========================================
model SeoPage {
  id              String   @id @default(uuid()) @db.Uuid
  slug            String   @unique @db.VarChar(200) // e.g. "tokyo-driver"
  prefecture      String   @db.VarChar(10)
  category        String   @db.VarChar(50)
  title           String   @db.VarChar(200)
  metaDescription String?  @map("meta_description") @db.VarChar(300)
  h1Text          String?  @map("h1_text") @db.VarChar(200)
  bodyContent     String?  @map("body_content")
  jobCount        Int      @default(0) @map("job_count")
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("seo_pages")
}
